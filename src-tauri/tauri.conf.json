{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skald",
  "version": "0.1.0",
  "identifier": "com.skald.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/AppData/Local/Skald/cache/covers/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "vlc-dist/libvlc.dll": "libvlc.dll",
      "vlc-dist/libvlccore.dll": "libvlccore.dll",
      "vlc-dist/vlc-cache-gen.exe": "vlc-cache-gen.exe",
      "vlc-dist/plugins/**/*": "plugins/",
      "bin/ffprobe.exe": "ffprobe.exe",
      "bin/tone.exe": "tone.exe"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "tsp": false,
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "installerHooks": "windows/hooks.nsh"
      }
    }
  }
}
