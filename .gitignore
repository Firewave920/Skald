Skald API Tokens.txt
*tokens*.txt
*tokens*.jsx

# Bundled VLC runtime — populated locally from the VLC installation.
# Not committed; build.rs copies these to the binary output directory.
src-tauri/vlc-dist/

# Bundled helper binaries (ffprobe = read metadata/chapters, tone = write).
# Not committed; fetched locally, build.rs copies them next to the binary.
src-tauri/bin/

# Personal notes / Obsidian vault
Vault/

# Memory profiling artifacts
Mrmory/

# Raw upstream font distributions (unused — only the subsetted -latin builds
# in src/assets/fonts/ are referenced by index.css). Leading slash anchors this
# to the repo root so it does NOT match src/assets/fonts/ (Git is case-
# insensitive on Windows, so an unanchored "Fonts/" would catch "fonts/" too).
/Fonts/
